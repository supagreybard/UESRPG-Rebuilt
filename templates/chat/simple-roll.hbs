<article class="uesrpg-rebuilt-chat-card">
  <header class="uesrpg-rebuilt-chat-card__header">
    <strong>{{title}}</strong>
    <div>{{documentName}}</div>
  </header>

  <div class="uesrpg-rebuilt-chat-card__body">
    <div><strong>{{localize 'UESRPG.Chat.roll'}}:</strong> {{result.total}} ({{result.formula}})</div>
    <div><strong>{{localize 'UESRPG.Chat.targetNumber'}}:</strong> {{result.targetNumber}}</div>
    <div><strong>{{localize 'UESRPG.Chat.result'}}:</strong> {{outcomeLabel}}</div>
    <div><strong>{{localize 'UESRPG.Chat.degrees'}}:</strong> {{result.degrees}}</div>
  </div>
</article>
