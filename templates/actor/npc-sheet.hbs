<form class='uesrpg-rebuilt-sheet' autocomplete='off'>
  <header class='uesrpg-rebuilt-sheet__header'>
    <img
      class='uesrpg-rebuilt-sheet__portrait'
      src='{{actor.img}}'
      data-edit='img'
      title='{{actor.name}}'
    />

    <div class='uesrpg-rebuilt-actor-sheet__header-copy'>
      <div
        class='uesrpg-rebuilt-sheet__title-row uesrpg-rebuilt-actor-sheet__title-row'
      >
        <div class='uesrpg-rebuilt-sheet__type'>{{typeLabel}}
          -
          {{sheetTitle}}</div>
      </div>

      <input
        class='uesrpg-rebuilt-sheet__name'
        name='name'
        type='text'
        value='{{actor.name}}'
        placeholder='{{localize "UESRPG.Fields.name"}}'
      />
    </div>
  </header>

  <section class='uesrpg-rebuilt-sheet__grid uesrpg-rebuilt-actor-sheet__grid'>
    <article
      class='uesrpg-rebuilt-card uesrpg-rebuilt-actor-sheet__card uesrpg-rebuilt-actor-sheet__card--resources'
    >
      <h2 class='uesrpg-rebuilt-card__heading'>{{localize
          'UESRPG.Sections.resources'
        }}</h2>

      <div class='uesrpg-rebuilt-actor-sheet__resource-list'>
        {{#each resourceFields as |resource|}}
          <div
            class='uesrpg-rebuilt-actor-sheet__resource'
            data-resource='{{resource.key}}'
          >
            <span class='uesrpg-rebuilt-field__label'>{{resource.label}}</span>
            <div
              class='uesrpg-rebuilt-field__pair uesrpg-rebuilt-actor-sheet__resource-pair'
            >
              <input
                name='system.resources.{{resource.key}}.value'
                type='number'
                value='{{resource.value}}'
              />
              <input
                name='system.resources.{{resource.key}}.max'
                type='number'
                value='{{resource.max}}'
              />
            </div>
          </div>
        {{/each}}
      </div>
    </article>

    <article
      class='uesrpg-rebuilt-card uesrpg-rebuilt-actor-sheet__card uesrpg-rebuilt-actor-sheet__card--attributes'
    >
      <h2 class='uesrpg-rebuilt-card__heading'>{{localize
          'UESRPG.Sections.attributes'
        }}</h2>

      <div
        class='uesrpg-rebuilt-field-grid uesrpg-rebuilt-field-grid--two uesrpg-rebuilt-actor-sheet__attribute-grid'
      >
        {{#each characteristicFields as |characteristic|}}
          <label
            class='uesrpg-rebuilt-field uesrpg-rebuilt-actor-sheet__attribute'
          >
            <span>{{characteristic.label}}</span>
            <input
              name='system.characteristics.{{characteristic.key}}'
              type='number'
              value='{{characteristic.value}}'
            />
          </label>
        {{/each}}
      </div>
    </article>

    <article
      class='uesrpg-rebuilt-card uesrpg-rebuilt-actor-sheet__card uesrpg-rebuilt-actor-sheet__card--prose'
    >
      <h2 class='uesrpg-rebuilt-card__heading'>{{localize
          'UESRPG.Sections.prose'
        }}</h2>

      <label class='uesrpg-rebuilt-field uesrpg-rebuilt-actor-sheet__prose'>
        <span>{{localize 'UESRPG.Fields.notes'}}</span>
        <textarea name='system.prose.notes'>{{system.prose.notes}}</textarea>
      </label>
    </article>
  </section>
</form>