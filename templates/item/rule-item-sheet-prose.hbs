<article
  class='tab {{#if tabs.prose.active}}active{{/if}} uesrpg-rebuilt-card uesrpg-rebuilt-item-sheet__card uesrpg-rebuilt-item-sheet__card--prose'
  data-group='primary'
  data-tab='prose'
>
  <h2 class='uesrpg-rebuilt-card__heading'>{{localize 'UESRPG.Sections.prose'}}</h2>

  <div class='uesrpg-rebuilt-item-sheet__prose-layout'>
    <label
      class='uesrpg-rebuilt-field uesrpg-rebuilt-item-sheet__prose-field uesrpg-rebuilt-item-sheet__prose-field--flavor'
    >
      <span>{{flavorTextField.label}}</span>
      <textarea name='system.{{flavorTextField.key}}'>{{flavorTextField.value}}</textarea>
    </label>

    <label class='uesrpg-rebuilt-field uesrpg-rebuilt-item-sheet__prose-field'>
      <span>{{localize 'UESRPG.Fields.description'}}</span>
      <prose-mirror
        name='system.prose.description'
        value='{{source.system.prose.description}}'
        compact
      ></prose-mirror>
    </label>

    <label class='uesrpg-rebuilt-field uesrpg-rebuilt-item-sheet__prose-field'>
      <span>{{localize 'UESRPG.Fields.notes'}}</span>
      <prose-mirror
        name='system.prose.notes'
        value='{{source.system.prose.notes}}'
        compact
      ></prose-mirror>
    </label>
  </div>
</article>
