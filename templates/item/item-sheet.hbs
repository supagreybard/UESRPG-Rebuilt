<form class='uesrpg-rebuilt-sheet' autocomplete='off'>
  <header class='uesrpg-rebuilt-sheet__header'>
    <img
      class='uesrpg-rebuilt-sheet__portrait'
      src='{{item.img}}'
      data-edit='img'
      title='{{item.name}}'
    />

    <div class='uesrpg-rebuilt-item-sheet__header-copy'>
      <div
        class='uesrpg-rebuilt-sheet__title-row uesrpg-rebuilt-item-sheet__title-row'
      >
        <div class='uesrpg-rebuilt-sheet__type'>{{typeLabel}}
          -
          {{sheetTitle}}</div>
      </div>

      <input
        class='uesrpg-rebuilt-sheet__name'
        name='name'
        type='text'
        value='{{item.name}}'
        placeholder='{{localize "UESRPG.Fields.name"}}'
      />

      {{#if isRuleItem}}
        {{#if headerFlavorText}}
          <div
            class='uesrpg-rebuilt-sheet__flavor-text uesrpg-rebuilt-item-sheet__flavor-text'
          >{{headerFlavorText}}</div>
        {{/if}}
      {{/if}}
    </div>
  </header>

  <section class='uesrpg-rebuilt-sheet__grid'>
    <article
      class='uesrpg-rebuilt-card uesrpg-rebuilt-item-sheet__card uesrpg-rebuilt-item-sheet__card--details'
    >
      <h2 class='uesrpg-rebuilt-card__heading'>{{localize
          'UESRPG.Sections.details'
        }}</h2>

      <div class='uesrpg-rebuilt-item-sheet__details-layout'>
        {{#if inventoryFields}}
          <section
            class='uesrpg-rebuilt-item-sheet__group uesrpg-rebuilt-item-sheet__group--inventory'
          >
            <div
              class='uesrpg-rebuilt-field-grid uesrpg-rebuilt-field-grid--two'
            >
              {{#each inventoryFields as |field|}}
                <label class='uesrpg-rebuilt-field'>
                  <span>{{field.label}}</span>
                  <input
                    name='system.{{field.key}}'
                    type='{{field.inputType}}'
                    value='{{field.value}}'
                    min='0'
                    step='any'
                  />
                </label>
              {{/each}}
            </div>
          </section>
        {{/if}}

        {{#if ruleFields}}
          <section
            class='uesrpg-rebuilt-item-sheet__group uesrpg-rebuilt-item-sheet__group--rules'
          >
            <div
              class='uesrpg-rebuilt-field-grid uesrpg-rebuilt-field-grid--two'
            >
              {{#each ruleFields as |field|}}
                {{#if field.isCheckbox}}
                  <label
                    class='uesrpg-rebuilt-field uesrpg-rebuilt-field--checkbox'
                  >
                    <input
                      name='system.{{field.key}}'
                      type='checkbox'
                      {{checked field.value}}
                    />
                    <span>{{field.label}}</span>
                  </label>
                {{else}}
                  <label class='uesrpg-rebuilt-field'>
                    <span>{{field.label}}</span>
                    <input
                      name='system.{{field.key}}'
                      type='{{field.inputType}}'
                      value='{{field.value}}'
                      min='{{field.min}}'
                      step='{{field.step}}'
                    />
                  </label>
                {{/if}}
              {{/each}}
            </div>
          </section>
        {{/if}}

        {{#if subtypeFields}}
          <section
            class='uesrpg-rebuilt-item-sheet__group uesrpg-rebuilt-item-sheet__group--subtype'
          >
            {{#each subtypeFields as |field|}}
              {{#if field.isCheckbox}}
                <label
                  class='uesrpg-rebuilt-field uesrpg-rebuilt-field--checkbox'
                >
                  <input
                    name='system.{{field.key}}'
                    type='checkbox'
                    {{checked field.value}}
                  />
                  <span>{{field.label}}</span>
                </label>
              {{else}}
                <label class='uesrpg-rebuilt-field'>
                  <span>{{field.label}}</span>
                  <input
                    name='system.{{field.key}}'
                    type='{{field.inputType}}'
                    value='{{field.value}}'
                  />
                </label>
              {{/if}}
            {{/each}}
          </section>
        {{/if}}
      </div>
    </article>

    <article
      class='uesrpg-rebuilt-card uesrpg-rebuilt-item-sheet__card uesrpg-rebuilt-item-sheet__card--prose'
    >
      <h2 class='uesrpg-rebuilt-card__heading'>{{localize 'UESRPG.Sections.prose'}}</h2>

      <div class='uesrpg-rebuilt-item-sheet__prose-layout'>
        {{#if flavorTextField}}
          <label
            class='uesrpg-rebuilt-field uesrpg-rebuilt-item-sheet__prose-field uesrpg-rebuilt-item-sheet__prose-field--flavor'
          >
            <span>{{flavorTextField.label}}</span>
            <textarea
              name='system.{{flavorTextField.key}}'
            >{{flavorTextField.value}}</textarea>
          </label>
        {{/if}}

        <label
          class='uesrpg-rebuilt-field uesrpg-rebuilt-item-sheet__prose-field'
        >
          <span>{{localize 'UESRPG.Fields.description'}}</span>
          <textarea
            name='system.prose.description'
          >{{system.prose.description}}</textarea>
        </label>

        <label
          class='uesrpg-rebuilt-field uesrpg-rebuilt-item-sheet__prose-field'
        >
          <span>{{localize 'UESRPG.Fields.notes'}}</span>
          <textarea name='system.prose.notes'>{{system.prose.notes}}</textarea>
        </label>
      </div>
    </article>
  </section>
</form>
