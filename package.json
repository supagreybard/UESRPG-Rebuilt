{
  "name": "uesrpg-rebuilt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node automation/prepare-dist-build.mjs && vite build && npm run packs:compile",
    "dev": "node automation/prepare-dist-build.mjs && npm run packs:compile && vite build --watch",
    "packs:clean": "node automation/compendium-packager.mjs clean",
    "packs:compile": "node automation/compendium-packager.mjs compile",
    "packs:extract": "node automation/compendium-packager.mjs extract",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@foundryvtt/foundryvtt-cli": "^3.0.3",
    "@eslint/js": "^9.23.0",
    "eslint": "^9.23.0",
    "fvtt-types": "github:League-of-Foundry-Developers/foundry-vtt-types#main",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0",
    "vite": "^6.2.2",
    "vite-plugin-static-copy": "^2.3.0"
  }
}
