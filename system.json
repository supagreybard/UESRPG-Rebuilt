{
  "id": "uesrpg",
  "title": "UESRPG",
  "description": "A system package to run and play UESRPG in foundry VTT",
  "version": "0.1.0",
  "compatibility": {
    "minimum": "13",
    "verified": "13"
  },
  "authors": [
    {
      "name": "UESRPG Contributors"
    }
  ],
  "esmodules": ["uesrpg.js"],
  "styles": ["styles/uesrpg.css"],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "documentTypes": {
    "Actor": {
      "character": {},
      "npc": {}
    },
    "Item": {
      "weapon": {},
      "gear": {},
      "ability": {}
    }
  },
  "grid": {
    "distance": 5,
    "units": "ft"
  },
  "primaryTokenAttribute": "resources.health",
  "secondaryTokenAttribute": "resources.stamina"
}
