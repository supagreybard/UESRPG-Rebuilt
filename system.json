{
  "id": "uesrpg-rebuilt",
  "title": "UESRPG Rebuilt",
  "description": "A system package to run and play the Unofficial Elder Scrolls RPG in Foundry VTT",
  "version": "0.1.0",
  "compatibility": {
    "minimum": "13",
    "verified": "13"
  },
  "authors": [
    {
      "name": "UESRPG Rebuilt Contributors"
    }
  ],
  "esmodules": ["uesrpg-rebuilt.js"],
  "styles": ["styles/uesrpg-rebuilt.css"],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "packs": [
    {
      "name": "traits",
      "label": "Traits",
      "type": "Item",
      "path": "packs/traits",
      "system": "uesrpg-rebuilt",
      "private": false
    },
    {
      "name": "powers",
      "label": "Powers",
      "type": "Item",
      "path": "packs/powers",
      "system": "uesrpg-rebuilt",
      "private": false
    },
    {
      "name": "races",
      "label": "Races",
      "type": "Item",
      "path": "packs/races",
      "system": "uesrpg-rebuilt",
      "private": false
    }
  ],
  "documentTypes": {
    "Actor": {
      "character": {},
      "npc": {}
    },
    "Item": {
      "weapon": {},
      "trait": {},
      "race": {},
      "power": {}
    }
  },
  "grid": {
    "distance": 5,
    "units": "ft"
  },
  "primaryTokenAttribute": "resources.health",
  "secondaryTokenAttribute": "resources.stamina"
}
